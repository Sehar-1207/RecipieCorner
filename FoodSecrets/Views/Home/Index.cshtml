@model IEnumerable<RecipeDto>
@{
    ViewData["Title"] = "Recipes";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

@{
    var cuisines = Model
        .Select(r => r.Cusine)
        .Where(c => !string.IsNullOrEmpty(c))
        .Distinct()
        .OrderBy(c => c);
}

<!-- ======================= HERO CAROUSEL & SEARCH SECTION ======================= -->
<!-- Carousel is now full-width, with a 3-second auto-play interval -->
<div id="recipeCarousel" class="carousel slide hero-section" data-bs-ride="carousel" data-bs-interval="3000">
    <div class="hero-overlay"></div>
    <div class="hero-content text-center text-light">
        <h1 class="display-4 text-warning fw-bold mb-4">Discover Delicious Recipes</h1>
        <form id="searchForm" class="mx-auto" style="max-width: 600px;">
            <div class="input-group input-group-lg">
                <input type="text" id="searchInput" name="query" class="form-control"
                       placeholder="Search for ingredients or dishes..." aria-label="Search recipes">
                <button class="btn btn-secondary" type="submit">
                    <i class="fas fa-search me-2"></i>Search
                </button>
            </div>
        </form>

    </div>

    <div class="carousel-indicators">
        <button type="button" data-bs-target="#recipeCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#recipeCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#recipeCarousel" data-bs-slide-to="2"></button>
    </div>

    <div class="carousel-inner">
        <!-- Removed data-bs-interval from individual items -->
        <div class="carousel-item active">
            <img src="~/images/food/682bcf3d-47a8-420a-9198-8bf21a63e345.jpg" class="d-block w-100" alt="Delicious Pasta">
        </div>
        <div class="carousel-item">
            <img src="~/images/food/5a7eb680-ed19-45df-b81a-5fb6f39c90f0.jpg" class="d-block w-100" alt="Fresh Salads">
        </div>
        <div class="carousel-item">
            <img src="~/images/food/4c53d026-a2c1-44a8-b5d2-fa54f7fe816f.jpg" class="d-block w-100" alt="Hearty Soups">
        </div>
    </div>
</div>


<div class="container wide-container my-5">

    <!-- ======================= CUISINE FILTER SECTION ======================= -->
    @if (cuisines.Any())
    {
        <div class="filter-section text-center mb-5">
            <h3 class="fw-light mb-4">Browse by Cuisine</h3>
            <div class="filter-pills">
                <a href="@Url.Action("Index")" class="filter-pill cuisine-filter active" data-cuisine="">All</a>
                @foreach (var cuisine in cuisines)
                {
                    <a href="@Url.Action("ByCuisine", new { cuisine })"
                       class="filter-pill cuisine-filter"
                       data-cuisine="@cuisine">
                        @cuisine
                    </a>
                }
            </div>
        </div>
    }

    <!-- ======================= RECIPE CARDS GRID ======================= -->
    <div id="recipe-list">
        @await Html.PartialAsync("_RecipeCardsPartial", Model)
    </div>
</div>

@section Scripts {
    <link href="~/css/recipeindex.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css" />
    <script>
        // --- REFACTORED SCRIPT ---
        // Combined event listeners to avoid repetition.
        document.addEventListener("DOMContentLoaded", function () {
            const buttons = document.querySelectorAll(".cuisine-filter");
            const recipeList = document.getElementById("recipe-list");
            const searchForm = document.getElementById("searchForm");
            const searchInput = document.getElementById("searchInput");

            // Cuisine filter AJAX
            buttons.forEach(btn => {
                btn.addEventListener("click", function (e) {
                    e.preventDefault();
                    const cuisine = this.getAttribute("data-cuisine");

                    fetch(`/Home/FilterByCuisine?cuisine=${encodeURIComponent(cuisine)}`)
                        .then(response => response.text())
                        .then(html => {
                            recipeList.innerHTML = html;
                            buttons.forEach(b => b.classList.remove("active"));
                            this.classList.add("active");
                        })
                        .catch(err => console.error("Error filtering recipes:", err));
                });
            });

            // Search AJAX
            searchForm.addEventListener("submit", function (e) {
                e.preventDefault();
                const query = searchInput.value;

                fetch(`/Home/Search?query=${encodeURIComponent(query)}`)
                    .then(response => response.text())
                    .then(html => {
                        recipeList.innerHTML = html;
                        // clear active cuisine filter since search overrides it
                        buttons.forEach(b => b.classList.remove("active"));
                    })
                    .catch(err => console.error("Error searching recipes:", err));
            });
        });

    </script>
}
