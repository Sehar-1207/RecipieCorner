@model ErrorViewModel
@{
    ViewData["Title"] = "Oops! Something went wrong";
}

<div class="text-center mt-5">
    <h1 class="text-warning">
        <i class="bi bi-emoji-frown"></i> Oops!
    </h1>
    <h4 class="text-muted">Something unexpected happened while processing your request.</h4>

    @if (Model.ShowRequestId)
    {
        <p class="mt-3">
            <small class="text-secondary">Request ID: <code>@Model.RequestId</code></small>
        </p>
    }

    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-house-door"></i> Back to Home
        </a>
        <a asp-controller="AuthAccount" asp-action="Login" class="btn btn-outline-secondary ms-2">
            <i class="bi bi-box-arrow-in-right"></i> Login Again
        </a>
    </div>

    <hr class="my-4" />

    <p class="text-muted small">
        If the problem continues, please <a href="/Support">contact support</a>.
        We're working hard to fix it!
    </p>
</div>
