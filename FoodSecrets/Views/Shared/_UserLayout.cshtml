@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    // This block is necessary to get the user's details for the navbar.
    var user = HttpContextAccessor.HttpContext?.User;

    var userName = user?.Identity?.IsAuthenticated == true
        ? user.Identity?.Name
        : "Guest";

    var userImage = user?.Claims.FirstOrDefault(c => c.Type == "ProfileImageUrl")?.Value
        ?? "/images/default-author.png"; 
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Recipe Corner</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="~/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <header>
        <!-- ======================= NAVBAR (MODIFIED) ======================= -->
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-secondary border-bottom box-shadow fixed-top">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">RecipeCorner</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">

                    @if (user?.Identity?.IsAuthenticated == true)
                    {
                        <!-- This is the only section that will now appear on the right side -->
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center " href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <img src="@userImage" alt="@userName" class="rounded-circle me-2" width="40" height="40" style="object-fit:cover;">
                                    @userName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-controller="AuthAccount" asp-action="Settings">
                                            <i class="bi bi-person-circle"></i> My Profile
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="AuthAccount" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-box-arrow-right"></i> Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>

                            </li>
                        </ul>
                    }

                </div>
            </div>
        </nav>
    </header>

    <!-- ======================= MAIN CONTENT AREA ======================= -->
    <!--  The rest of the page content is rendered inside the container. -->
    <div class="">
        <main role="main" class="pb-2">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>