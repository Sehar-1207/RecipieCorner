@model InstructionDto

@{
    ViewData["Title"] = "Create a New Instruction";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container mt-4" style="max-width: 800px;">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-light border-0 pt-3 pb-3">
            <h4 class="mb-0">
                <i class="bi bi-journal-plus me-2"></i>New Recipe Instruction
            </h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div class="row g-3">
                    <!-- Left Column -->
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <div class="form-floating mb-3">
                                <input asp-for="RecipeId" type="number" class="form-control" placeholder="Recipe Id" />
                                <label asp-for="RecipeId">Recipe Id</label>
                                <span asp-validation-for="RecipeId" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Order" type="number" class="form-control" placeholder="Step Number" />
                            <label asp-for="Order">Step Number</label>
                            <span asp-validation-for="Order" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Full Width Fields -->
                    <div class="col-12">
                        <div class="form-floating mb-3">
                            <textarea asp-for="StepInstruction" class="form-control" placeholder="Instruction" style="height: 120px"></textarea>
                            <label asp-for="StepInstruction">Instruction</label>
                            <span asp-validation-for="StepInstruction" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-floating mb-3">
                            <input asp-for="Tip" class="form-control" placeholder="Optional Tip" />
                            <label asp-for="Tip">Optional Tip</label>
                            <span asp-validation-for="Tip" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-circle me-1"></i> Save Instruction
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}