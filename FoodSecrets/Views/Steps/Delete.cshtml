@model InstructionDto

@{
    ViewData["Title"] = "Delete Instruction";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Add a reference to Bootstrap Icons if needed -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<div class="row justify-content-center mt-5">
    <div class="col-lg-8">
        
        <!-- Using an Alert for a more focused, cautionary feel -->
        <div class="alert alert-danger shadow-sm p-4" role="alert">
            <h4 class="alert-heading">
                <i class="bi bi-exclamation-octagon-fill me-2"></i>Hold on a second...
            </h4>
            <p>You are about to permanently delete an instruction. This is an irreversible action, and the data will be gone forever.</p>
            
            <hr>

            <div class="p-3 my-3 bg-danger-subtle border border-danger-subtle rounded">
                <p class="text-danger-emphasis small fw-bold mb-2 text-uppercase">You will be deleting the following:</p>
                <dl class="row mb-0">
                    <dt class="col-sm-3">Step:</dt>
                    <dd class="col-sm-9">
                        <span class="badge text-bg-primary rounded-pill fs-6">@Model.Order</span>
                    </dd>

                    <dt class="col-sm-3 mt-2">Instruction:</dt>
                    <dd class="col-sm-9 mt-2">
                        <p class="mb-0">"@Model.StepInstruction"</p>
                    </dd>

                    @if (!string.IsNullOrWhiteSpace(Model.Tip))
                    {
                        <dt class="col-sm-3 mt-2">Tip:</dt>
                        <dd class="col-sm-9 mt-2 text-muted">
                            <em>@Model.Tip</em>
                        </dd>
                    }
                </dl>
            </div>

            <p class="mb-0">Please confirm that you want to proceed.</p>

            <div class="mt-4 d-flex justify-content-end">
                <form asp-action="Delete" method="post">
                    <!-- Crucial hidden input to identify the item -->
                    <input type="hidden" asp-for="Id" />

                    <a asp-action="Index" class="btn btn-secondary me-2">
                        <i class="bi bi-x-circle me-1"></i> Cancel
                    </a>
                    
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash3-fill me-1"></i> Permanently Delete
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}