@model InstructionDto

@{
    ViewData["Title"] = "Edit Instruction";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Add a reference to Bootstrap Icons if needed -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<style>
    .preview-card {
        background-color: #f8f9fa;
        border-radius: 0.5rem;
        border: 1px solid #dee2e6;
        height: 100%;
        position: sticky; /* Keeps preview in view on scroll */
        top: 20px;
    }

    .preview-header {
        border-bottom: 1px solid #dee2e6;
    }

    .preview-step-number {
        font-size: 3rem;
        font-weight: 700;
        color: #0d6efd;
        line-height: 1;
    }

    .preview-instruction-text {
        font-size: 1.1rem;
        line-height: 1.6;
    }

    .preview-tip {
        background-color: #e9ecef;
        border-left: 4px solid #0d6efd;
        font-style: italic;
    }
</style>

<div class="container-fluid">
    <div class="row g-4">
        <!-- Column 1: The Edit Form -->
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Edit Instruction
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post" id="editForm">
                        <input type="hidden" asp-for="Id" />

                        <!-- RecipeId should be hidden. The user is editing an instruction,
                             not re-assigning it to a different recipe. -->
                        <input type="hidden" asp-for="RecipeId" />

                        <div class="mb-3">
                            <label asp-for="Order" class="form-label fw-bold">Step Number</label>
                            <input asp-for="Order" type="number" class="form-control" id="inputOrder" />
                            <span asp-validation-for="Order" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StepInstruction" class="form-label fw-bold">Step Instruction</label>
                            <textarea asp-for="StepInstruction" class="form-control" rows="6" id="inputInstruction"></textarea>
                            <span asp-validation-for="StepInstruction" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Tip" class="form-label fw-bold">Optional Pro Tip</label>
                            <input asp-for="Tip" class="form-control" id="inputTip" />
                            <span asp-validation-for="Tip" class="text-danger"></span>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light text-end">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </a>
                    <button type="submit" form="editForm" class="btn btn-success">
                        <i class="bi bi-check-circle me-1"></i>Save Changes
                    </button>
                </div>
            </div>
        </div>

        <!-- Column 2: The Live Preview -->
        <div class="col-lg-6">
            <div class="preview-card">
                <div class="preview-header p-3">
                    <h5 class="mb-0 text-muted">
                        <i class="bi bi-eye me-2"></i>Live Preview
                    </h5>
                </div>
                <div class="p-4 d-flex align-items-start gap-4">
                    <div id="previewOrder" class="preview-step-number">@Model.Order</div>
                    <div class="flex-grow-1">
                        <p id="previewInstruction" class="preview-instruction-text mb-0">
                            @Model.StepInstruction
                        </p>

                        <div id="previewTipWrapper" class="mt-3 @(string.IsNullOrWhiteSpace(Model.Tip) ? "d-none" : "")">
                            <div class="preview-tip p-3 rounded">
                                <strong>Tip:</strong> <span id="previewTip">@Model.Tip</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Get references to form inputs
            const inputOrder = document.getElementById('inputOrder');
            const inputInstruction = document.getElementById('inputInstruction');
            const inputTip = document.getElementById('inputTip');

            // Get references to preview elements
            const previewOrder = document.getElementById('previewOrder');
            const previewInstruction = document.getElementById('previewInstruction');
            const previewTipWrapper = document.getElementById('previewTipWrapper');
            const previewTip = document.getElementById('previewTip');

            // Update functions
            const updateOrder = () => {
                previewOrder.textContent = inputOrder.value || '#';
            };

            const updateInstruction = () => {
                previewInstruction.textContent = inputInstruction.value || 'Your instruction will appear here...';
            };

            const updateTip = () => {
                const tipValue = inputTip.value.trim();
                if (tipValue) {
                    previewTip.textContent = tipValue;
                    previewTipWrapper.classList.remove('d-none');
                } else {
                    previewTipWrapper.classList.add('d-none');
                }
            };

            // Attach event listeners
            inputOrder.addEventListener('input', updateOrder);
            inputInstruction.addEventListener('input', updateInstruction);
            inputTip.addEventListener('input', updateTip);
        });
    </script>
}