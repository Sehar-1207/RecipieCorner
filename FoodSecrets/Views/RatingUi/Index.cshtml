@model List<RatingDto>

@{
    ViewData["Title"] = "Ratings Feed";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Custom CSS for the design -->
<style>
    body {
        background-color: #f8f9fa; /* A light, clean background */
    }

    .rating-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        border: none;
        border-radius: 15px;
    }

        .rating-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1) !important;
        }

    .card-recipe-name {
        font-weight: 600;
        color: #333;
        text-decoration: none;
    }

        .card-recipe-name:hover {
            color: #0d6efd; /* Bootstrap primary blue */
        }

    .user-avatar {
        width: 45px;
        height: 45px;
        object-fit: cover;
    }

    .card-stars .star {
        font-size: 1.2rem;
    }

    .card-footer {
        background-color: #f8f9fa;
        border-top: 1px solid #e9ecef;
    }
</style>

<div class="container my-5">
    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">Ratings Feed</h1>
        <p class="lead text-muted">See what everyone is saying about the recipes.</p>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.Error))
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }
    else if (!Model.Any())
    {
        <div class="text-center p-5 bg-light rounded-3">
            <i class="fas fa-comments fa-3x text-muted mb-3"></i>
            <h3 class="text-muted">No Ratings Yet</h3>
            <p>Be the first one to rate a recipe!</p>
        </div>
    }
    else
    {
        <!-- Responsive Grid for Rating Cards -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var rating in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm rating-card">
                        <div class="card-body">

                            <!-- User Info Header -->
                            <div class="d-flex align-items-center mb-3">
                                <img src="@rating.ProfileImageUrl" alt="@rating.UserName" class="rounded-circle user-avatar" />
                                <div class="ms-3">
                                    <h6 class="card-title mb-0">@rating.UserName</h6>
                                    <small class="text-muted">@rating.commentAt.ToString("MMMM dd, yyyy")</small>
                                </div>
                            </div>

                            <hr />

                            <!-- Recipe Name -->
                            <h5 class="mb-2">
                                <a asp-controller="RecipeUi" asp-action="Details" asp-route-id="@rating.RecipeId" class="card-recipe-name">
                                    @rating.RecipeName
                                </a>
                            </h5>

                            <!-- Stars -->
                            <div class="mb-3 card-stars">
                                @for (int i = 0; i < rating.Stars; i++)
                                {
                                    <span class="text-warning star">&#9733;</span>
                                }
                                @for (int i = rating.Stars; i < 5; i++)
                                {
                                    <span class="text-muted star">&#9734;</span>
                                }
                            </div>

                            <!-- Comment -->
                            <p class="card-text">
                                @(string.IsNullOrEmpty(rating.Comment) ? "No comment provided." : $"\"{rating.Comment}\"")
                            </p>
                        </div>

                        <!-- Card Footer with Actions -->
                        <div class="card-footer d-flex justify-content-end gap-2">
                            <a asp-controller="RatingUi" asp-action="Edit" asp-route-id="@rating.Id" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-edit me-1"></i> Edit
                            </a>
                            <a asp-controller="RatingUi" asp-action="Delete" asp-route-id="@rating.Id" class="btn btn-sm btn-outline-danger">
                                <i class="fas fa-trash-alt me-1"></i> Delete
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <!-- Font Awesome for icons -->
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
}