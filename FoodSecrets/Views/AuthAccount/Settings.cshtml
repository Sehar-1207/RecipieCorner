@using System.Security.Claims
@model UpdateProfile
@{
    ViewData["Title"] = "Settings";
    if (User.IsInRole("Admin"))
    {
        Layout = "~/Views/Shared/_DashboardLayout.cshtml";  // Admin layout
    }
    else
    {
        Layout = "~/Views/Shared/_UserLayout.cshtml"; // User layout
    }
}
@{
    var isAdmin = User.IsInRole("Admin");
}
<div class="container mt-5 justify-content-center align-content-center">

    <div class="card border-0 shadow-lg mt-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
        <div class="card-header bg-transparent border-bottom-0 pt-4 px-4 mt-3">
            <h3 class="mb-0">Account Settings</h3>
            <p class="text-muted">Manage your profile information and preferences.</p>
        </div>
        <div class="card-body p-4">
            <form asp-action="Settings" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="ProfileImageUrl" />

                <div class="row">
                    <!-- Left Column: Profile Picture -->
                    <div class="col-md-4 text-center">
                        <img src="@(string.IsNullOrEmpty(Model.ProfileImageUrl) ? "/images/default-avatar.png" : Model.ProfileImageUrl)"
                             alt="Profile Image"
                             id="profileImagePreview"
                             class="rounded-circle mb-3"
                             style="width: 150px; height: 150px; object-fit: cover; border: 4px solid #f8f9fa;" />

                        <!-- This file input is hidden and triggered by the label -->
                        <input asp-for="ProfileImage" type="file" accept="image/*" class="d-none" id="ProfileImage" />

                        <p class="text-muted small mt-2">JPG, GIF or PNG. 1MB max.</p>

                        <!-- This label acts as the visible button for the file input -->
                        <label for="ProfileImage" class="btn btn-outline-primary">
                            Change Picture
                        </label>
                    </div>

                    <!-- Right Column: Form Fields -->
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-bold">Full Name</label>
                            <input asp-for="FullName" class="form-control" placeholder="Enter your full name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-bold">Email</label>
                            <!-- ✅ FIXED: Changed disabled to readonly -->
                            <input asp-for="Email" class="form-control bg-light" readonly />
                            <small class="form-text text-muted">Your email address is linked to your account and cannot be changed.</small>
                        </div>

                        <hr class="my-4">

                        <div class="text-end">
                            <!-- ✅ IMPROVED: Button styles to match screenshot -->
                            <button type="submit" class="btn btn-success px-4 py-2">Save Changes</button>
                            <a asp-action="Index"
                               asp-controller="@(isAdmin ? "RecipeUi" : "Home")"
                               class="btn btn-light border">
                                Cancel
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Simple script to preview the new profile image before uploading
        document.getElementById('ProfileImage').addEventListener('change', function (event) {
            const [file] = event.target.files;
            if (file) {
                document.getElementById('profileImagePreview').src = URL.createObjectURL(file);
            }
        });
    </script>
}